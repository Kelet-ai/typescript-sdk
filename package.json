{
  "name": "kelet",
  "version": "0.10.4",
  "description": "Kelet TypeScript SDK for AI observability",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./aisdk": {
      "types": "./dist/aisdk.d.ts",
      "import": "./dist/aisdk.js"
    },
    "./reasoning/register": {
      "types": "./dist/reasoning/register.d.ts",
      "import": "./dist/reasoning/register.js"
    },
    "./claude-agent-sdk": {
      "types": "./dist/claude-agent-sdk/index.d.ts",
      "import": "./dist/claude-agent-sdk/index.js"
    },
    "./claude-agent-sdk/shim": {
      "types": "./dist/claude-agent-sdk/shim.d.ts",
      "import": "./dist/claude-agent-sdk/shim.js"
    },
    "./claude-agent-sdk/register": {
      "types": "./dist/claude-agent-sdk/register.d.ts",
      "import": "./dist/claude-agent-sdk/register.js"
    },
    "./temporal": {
      "types": "./dist/temporal/index.d.ts",
      "import": "./dist/temporal/index.js"
    },
    "./temporal/workflow-interceptors": {
      "types": "./dist/temporal/workflow-interceptors.d.ts",
      "import": "./dist/temporal/workflow-interceptors.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "test": "bun test",
    "test:node": "node --import tsx --test src/**/*.test.ts",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "build": "bun run build:js && bun run build:types",
    "build:js": "bun build ./src/index.ts ./src/aisdk.ts ./src/reasoning/register.ts ./src/claude-agent-sdk/index.ts ./src/claude-agent-sdk/shim.ts ./src/claude-agent-sdk/register.ts ./src/temporal/index.ts ./src/temporal/workflow-interceptors.ts --outdir ./dist --target node --format esm --splitting --external '@temporalio/*' --external 'ai' --external '@ai-sdk/*'",
    "build:types": "tsc --project tsconfig.build.json",
    "prepublishOnly": "bun run build",
    "verify-build": "bun test ./.github/build-verification.test.ts",
    "clean": "rm -rf dist",
    "checks": "bun run typecheck && bun test --run"
  },
  "keywords": [
    "kelet",
    "ai",
    "observability",
    "opentelemetry",
    "tracing",
    "vercel-ai-sdk"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Kelet-ai/typescript-sdk"
  },
  "bugs": {
    "url": "https://github.com/Kelet-ai/typescript-sdk/issues"
  },
  "homepage": "https://kelet.ai",
  "devDependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.149",
    "@opentelemetry/api": "^1.9.1",
    "ai": "^6.0.191",
    "@ai-sdk/otel": "^1.0.0-beta.6",
    "@opentelemetry/api-logs": "^0.57.2",
    "@opentelemetry/context-async-hooks": "^1.30.1",
    "@opentelemetry/exporter-logs-otlp-http": "^0.57.2",
    "@opentelemetry/exporter-trace-otlp-http": "^0.57.2",
    "@opentelemetry/instrumentation": "^0.57.2",
    "@opentelemetry/resources": "^1.30.1",
    "@opentelemetry/sdk-logs": "^0.57.2",
    "@opentelemetry/sdk-trace-base": "^1.30.1",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "@temporalio/client": "^1.17.2",
    "@temporalio/common": "^1.17.2",
    "@temporalio/interceptors-opentelemetry": "^1.17.2",
    "@temporalio/plugin": "^1.17.2",
    "@temporalio/testing": "^1.17.2",
    "@temporalio/worker": "^1.17.2",
    "@temporalio/workflow": "^1.17.2",
    "@types/bun": "latest",
    "tsx": "^4.22.3"
  },
  "peerDependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.0",
    "@opentelemetry/api": "^1.0.0",
    "@opentelemetry/api-logs": "^0.50.0",
    "@opentelemetry/context-async-hooks": "^1.0.0",
    "@opentelemetry/exporter-logs-otlp-http": "^0.50.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.50.0",
    "@opentelemetry/instrumentation": "^0.50.0",
    "@opentelemetry/resources": "^1.0.0",
    "@opentelemetry/sdk-logs": "^0.50.0",
    "@opentelemetry/sdk-trace-base": "^1.0.0",
    "ai": "^4.3.19 || ^5.0.0 || ^6.0.74 || ^7.0.0-beta",
    "@ai-sdk/otel": "^1.0.0-beta.6",
    "typescript": "^5",
    "@temporalio/client": "^1.17.0",
    "@temporalio/worker": "^1.17.0",
    "@temporalio/workflow": "^1.17.0",
    "@temporalio/common": "^1.17.0",
    "@temporalio/plugin": "^1.17.0",
    "@temporalio/interceptors-opentelemetry": "^1.17.0",
    "@temporalio/activity": "^1.17.2"
  },
  "peerDependenciesMeta": {
    "@anthropic-ai/claude-agent-sdk": {
      "optional": true
    },
    "@opentelemetry/api-logs": {
      "optional": true
    },
    "@opentelemetry/exporter-logs-otlp-http": {
      "optional": true
    },
    "@opentelemetry/sdk-logs": {
      "optional": true
    },
    "ai": {
      "optional": true
    },
    "@ai-sdk/otel": {
      "optional": true
    },
    "typescript": {
      "optional": true
    },
    "@temporalio/client": {
      "optional": true
    },
    "@temporalio/worker": {
      "optional": true
    },
    "@temporalio/workflow": {
      "optional": true
    },
    "@temporalio/common": {
      "optional": true
    },
    "@temporalio/plugin": {
      "optional": true
    },
    "@temporalio/interceptors-opentelemetry": {
      "optional": true
    },
    "@temporalio/activity": {
      "optional": true
    }
  }
}
